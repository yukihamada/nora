# Model settings
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4
OPENAI_API_KEY=your_openai_api_key_here

# Web browsing settings
USE_PUPPETEER=true
BROWSER_HEADLESS=true

# GitHub settings
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username_here

# AWS settings
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Google Cloud settings
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_CREDENTIALS_FILE=/path/to/your/credentials.json

# Stripe settings
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Google AdSense settings
ADSENSE_CLIENT_ID=your_adsense_client_id_here
ADSENSE_CLIENT_SECRET=your_adsense_client_secret_here

# Google Ads settings
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret_here
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token_here
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token_here

# Namecheap settings
NAMECHEAP_API_KEY=your_namecheap_api_key_here
NAMECHEAP_USERNAME=your_namecheap_username_here
NAMECHEAP_CLIENT_IP=your_client_ip_here